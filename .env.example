# Copy this file to .env.local and fill in the values.
# The enquiry form (admissions + contact) sends email through Gmail SMTP.

# The Gmail address that sends the mail.
SMTP_USER=creativekidsacademyng@gmail.com

# A Google *App Password* (NOT your normal Gmail password).
# Create one at: Google Account -> Security -> 2-Step Verification -> App passwords.
# It's a 16-character code; paste it here without spaces.
SMTP_PASS=

# Where enquiries are delivered (defaults to SMTP_USER if left blank).
ENQUIRY_TO=creativekidsacademyng@gmail.com
